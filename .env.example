# =============================================================================
# Park Routing — environment template
# Copy to `.env` and adjust. Never commit `.env` (it is gitignored).
#
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Development (API via `cargo run`, DB/Redis from `docker compose up -d db redis`)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/park_routing
# REDIS_URL=redis://localhost:6379
# RUST_LOG=info,sqlx=warn
# LISTEN_ADDR=127.0.0.1:8080
# PG_POOL_MAX_CONNECTIONS=10
# REDIS_POOL_MAX_SIZE=16
# CACHE_GRID_PRECISION=4
# CACHE_TTL_SECONDS=600

# -----------------------------------------------------------------------------
# Production — local/on-prem server (`docker compose up -d` on your own hardware)
#
# - API, Postgres, and Redis on the same host (Docker Compose).
# - Use service hostnames `db` and `redis` (Docker network), not localhost.
# - Set the same POSTGRES_PASSWORD in this file and in docker-compose.yml
#   under the `db` service `environment` block.
# - Do not publish 5432/6379 to the internet; expose only 8080 (or a reverse proxy).
# - Put nginx/Caddy in front with TLS if clients connect from outside the LAN.
# -----------------------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-a-long-random-secret
POSTGRES_DB=park_routing

DATABASE_URL=postgres://postgres:change-me-use-a-long-random-secret@db:5432/park_routing
REDIS_URL=redis://redis:6379

RUST_LOG=info,park_routing_api=info,sqlx=warn,tower_http=warn
LISTEN_ADDR=0.0.0.0:8080

PG_POOL_MAX_CONNECTIONS=30
REDIS_POOL_MAX_SIZE=64

CACHE_GRID_PRECISION=4
CACHE_TTL_SECONDS=600
